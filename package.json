{
  "name": "licencias",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "bun run test:int && bun run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" bun exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "update": "npx skills update && ncu -i"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/payload-cloud": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/sdk": "3.83.0",
    "@payloadcms/storage-s3": "3.83.0",
    "@payloadcms/ui": "3.83.0",
    "@tabler/icons-react": "3.41.1",
    "@tailwindcss/postcss": "4.2.3",
    "@tanstack/react-table": "8.21.3",
    "client-only": "0.0.1",
    "cross-env": "10.1.0",
    "dotenv": "17.4.2",
    "graphql": "16.13.2",
    "next": "16.2.4",
    "payload": "3.83.0",
    "postcss": "8.5.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.73.1",
    "server-only": "0.0.1",
    "sharp": "0.34.5",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "daisyui": "5.5.19",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "jsdom": "29.0.2",
    "playwright": "1.59.1",
    "playwright-core": "1.59.1",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5"
  }
}
